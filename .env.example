# ==============================================================
# 🔐 CURHATBOX ENVIRONMENT BLUEPRINT
# Jangan pernah memasukkan nilai rahasia asli ke dalam file ini!
# Saat mengunduh dari GitHub, salin file ini menjadi ".env"
# perintah: cp .env.example .env
# ==============================================================

# [1] Keamanan Django (Django Security)
# Ganti dengan secret key unik milik Anda sendiri (minimal 50 karakter)
SECRET_KEY=ganti_dengan_kunci_rahasia_yang_sangat_panjang_dan_acak

# [2] Mode Pengembangan (Debug Mode)
# Ubah Ke False jika ingin menaikkan ke Production (VPS)
DEBUG=True

# [3] Akses Host (Allowed Hosts)
# Daftar domain atau IP yang diizinkan memuat aplikasi (pisahkan dengan koma)
ALLOWED_HOSTS=127.0.0.1,localhost,yourdomain.com

# [4] Basis Data PostgreSQL (Apabila tidak menggunakan SQLite3 bawahan)
# (Opsional jika ingin menggunakan PostgreSQL di Production)
DB_NAME=curhatbox_db
DB_USER=curhatbox_user
DB_PASSWORD=password_database_anda
DB_HOST=127.0.0.1
DB_PORT=5432

# [5] Pengaturan Celery & Redis (Untuk WebSockets dan Background Tasks)
# URL Broker Redis (Default lokal)
CELERY_BROKER_URL=redis://127.0.0.1:6379/0

# [6] Pengaturan Email (Reset Password / Login Link)
# (Opsional) Menggunakan Mailgun atau layanan SMTP lainnya
MAILGUN_API_KEY=key-xxxxxxxxxxxxxxxxx
MAILGUN_SENDER_DOMAIN=sandboxxxxxxxxxxxxxx.mailgun.org
DEFAULT_FROM_EMAIL=no-reply@yourdomain.com
