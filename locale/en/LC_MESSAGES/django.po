msgid "Buka CurhatBox di <b>Safari</b>."
msgstr "[EN] Buka CurhatBox di <b>Safari</b>."

#: main/templates/main/install.html:53
msgid "Klik tombol <b>Share</b> (kotak dengan panah ke atas)."
msgstr "[EN] Klik tombol <b>Share</b> (kotak dengan panah ke atas)."

#: main/templates/main/install.html:54
msgid "Geser ke bawah dan pilih <b>Add to Home Screen</b>."
msgstr "[EN] Geser ke bawah dan pilih <b>Add to Home Screen</b>."

#: main/templates/main/install.html:67
msgid "Gunakan <b>Google Chrome</b> atau <b>Edge</b>."
msgstr "[EN] Gunakan <b>Google Chrome</b> atau <b>Edge</b>."

#: main/templates/main/install.html:68
msgid "Klik ikon monitor dengan panah bawah di sebelah bintang (Address Bar)."
msgstr ""
"[EN] Klik ikon monitor dengan panah bawah di sebelah bintang (Address Bar)."

