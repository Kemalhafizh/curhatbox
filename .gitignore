# CurhatBox Hardened .gitignore

# 🔑 Secrets & Environment
.env
secret.key
*.pem
*.key

# 📦 Databases
db.sqlite3
*.db
*.sqlite3-journal

# 🐍 Python
__pycache__/
*.py[cod]
*$py.class
venv/
.venv/
env/
.env/
build/
dist/
*.egg-info/

# 🌐 Django Specific
staticfiles/
media/
*.log
local_settings.py

# 💻 IDEs & Editors
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# 🧪 Research & Temp
/tmp/
.ipynb_checkpoints/
scripts/test_*.py
